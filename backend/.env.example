# ── Database ────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite:///./opportunities.db
# Docker Compose / production (Postgres):
# DATABASE_URL=postgresql+psycopg2://opportunity:opportunity@localhost:5432/opportunityfinder

# ── Google Custom Search API (optional) ─────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ── Scraping behaviour ───────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
MAX_RESULTS_PER_QUERY=10
REQUEST_DELAY_SECONDS=2.0
REQUEST_TIMEOUT=15
MAX_RETRIES=3
RSS_MAX_ENTRIES_PER_FEED=25

# ── Deployment ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Cloud platforms often set PORT instead of API_PORT:
# PORT=8000
ENABLE_SCHEDULER=true
CORS_ORIGINS=*
