# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./opportunities.db

# ── Google Custom Search API (optional) ─────────────────────
# Free tier = 100 queries/day.
# Without this, the app falls back to the googlesearch-python
# library which scrapes public Google results.
# Get keys here: https://developers.google.com/custom-search/v1/introduction
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ── Scraping behaviour ───────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6     # how often the scheduler re-scrapes
MAX_RESULTS_PER_QUERY=10    # links fetched per Google query
REQUEST_DELAY_SECONDS=2.0   # polite delay between HTTP requests
REQUEST_TIMEOUT=15          # seconds before giving up on a page
MAX_RETRIES=3               # retry count per failed request

# ── API server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
